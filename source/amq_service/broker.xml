<?xml version='1.0'?>
<configuration xmlns="urn:activemq"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

   <core xmlns="urn:activemq:core">

      <name>mars-broker</name>

      <security-enabled>false</security-enabled>
      <persistence-enabled>false</persistence-enabled>
      <journal-type>NIO</journal-type>

      <acceptors>
         <acceptor name="artemis">
            tcp://0.0.0.0:61616?protocols=AMQP,CORE,MQTT,STOMP
         </acceptor>
      </acceptors>

      <addresses>

      <address name="sensor.events">
         <multicast/>
      </address>

         <address name="actuator.states">
            <multicast>
               <queue name="actuator.states"/>
            </multicast>
         </address>

         <address name="actuator.commands">
            <anycast>
               <queue name="actuator.commands"/>
            </anycast>
         </address>

      </addresses>

   </core>

</configuration>
