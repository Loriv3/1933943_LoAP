{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "topic.airlock.v1",
    "type": "object",
    "properties": {
        "topic": {
            "type": "string",
            "description": "The topic this data refers to.",
            "pattern": "^[^\\.]$"
        },
        "event_time": {
            "type": "string",
            "format": "date-time",
            "pattern": "^[0-9\\-]+T[0-9:]+\\.[0-9]+(Z|\\+[0-9:]+)?$",
            "description": "The time at which this event was emitted."
        },
        "airlock_id": {
            "type": "string",
            "pattern": "^[^\\.]$"
        },
        "cycles_per_hour": {
            "type": "number"
        },
        "last_state": {
            "enum": [
                "IDLE",
                "PRESSURIZING",
                "DEPRESSURIZING"
            ]
        }
    },
    "required": [
        "topic",
        "event_time",
        "airlock_id",
        "cycles_per_hour",
        "last_state"
    ]
}
