{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "topic.power.v1",
    "type": "object",
    "properties": {
        "topic": {
            "type": "string",
            "description": "The topic this data refers to.",
            "pattern": "^[^\\.]$"
        },
        "event_time": {
            "type": "string",
            "format": "date-time",
            "pattern": "^[0-9\\-]+T[0-9:]+\\.[0-9]+(Z|\\+[0-9:]+)?$",
            "description": "The time at which this event was emitted."
        },
        "subsystem": {
            "type": "string",
            "pattern": "^[^\\.]$"
        },
        "power_kw": {
            "type": "number"
        },
        "voltage_v": {
            "type": "number"
        },
        "current_a": {
            "type": "number"
        },
        "cumulative_kwh": {
            "type": "number"
        }
    },
    "required": [
        "topic",
        "event_time",
        "subsystem",
        "power_kw",
        "voltage_v",
        "current_a",
        "cumulative_kwh"
    ]
}
